// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id              Int      @id @default(autoincrement())
  supabaseUid     String   @unique // UID proporcionado por Supabase Auth
  nombre          String
  email           String   @unique
  fechaCreacion   DateTime @default(now())
  pedidos         Pedido[]
}

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  productos   Producto[]
}

model Producto {
  id          Int        @id @default(autoincrement())
  categoriaId Int
  categoria   Categoria  @relation(fields: [categoriaId], references: [id])
  nombre      String
  descripcion String?
  precio      Decimal    @db.Decimal(10, 2)
  variantes   Variante[]
}

model Variante {
  id             Int             @id @default(autoincrement())
  productoId     Int
  producto       Producto        @relation(fields: [productoId], references: [id])
  talla          String
  color          String
  stock          Int             @default(0)
  detallesPedido DetallePedido[]

  // Evitar Variantes duplicadas con misma talla y color en un mismo producto
  @@unique([productoId, talla, color])
}

model Pedido {
  id             Int             @id @default(autoincrement())
  usuarioId      Int
  usuario        Usuario         @relation(fields: [usuarioId], references: [id])
  estado         EstadoPedido    @default(PENDIENTE)
  metodoEntrega  MetodoEntrega
  direccionEnvio String?         // Opcional, solo si el método es Envío a Domicilio
  subtotal       Decimal         @db.Decimal(10, 2)
  total          Decimal         @db.Decimal(10, 2)
  fechaCreacion  DateTime        @default(now())
  detalles       DetallePedido[]
}

model DetallePedido {
  id             Int      @id @default(autoincrement())
  pedidoId       Int
  pedido         Pedido   @relation(fields: [pedidoId], references: [id])
  varianteId     Int
  variante       Variante @relation(fields: [varianteId], references: [id])
  cantidad       Int
  precioUnitario Decimal  @db.Decimal(10, 2)
}

enum EstadoPedido {
  PENDIENTE
  PREPARANDO
  LISTO_PARA_RETIRO
  EN_TRANSITO
  ENTREGADO
}

enum MetodoEntrega {
  RETIRO_TIENDA
  ENVIO_DOMICILIO
}
