# Copia este archivo como ".env" (sin el ".example") y ajusta si tu instancia se llama distinto.
# NO subas el archivo ".env" real a ningún repositorio: contiene datos de tu entorno local.

# Instancia de SQL Server. En tu caso: (localdb)\MSSQLLocalDB
DB_SERVER=(localdb)\MSSQLLocalDB

# Base de datos creada con tu script (CREATE DATABASE StyleStoreDB)
DB_DATABASE=StyleStoreDB

# Nombre EXACTO del driver ODBC instalado en tu PC. Verifícalo en:
# Panel de Windows -> "Origenes de datos ODBC (64 bits)" -> pestaña "Controladores".
# Ahí debe aparecer algo como "ODBC Driver 17 for SQL Server" o "ODBC Driver 18 for SQL Server".
# Si el tuyo es la versión 18, cambia esta línea a: ODBC Driver 18 for SQL Server
DB_DRIVER=ODBC Driver 17 for SQL Server

# Puerto donde corre esta API (Android usará http://10.0.2.2:PORT/ desde el emulador)
PORT=3000

# Clave secreta para firmar los tokens JWT del login. Es solo para desarrollo
# local; cámbiala por cualquier texto largo y random. No la compartas si algún
# día este proyecto sale de tu PC.
JWT_SECRET=stylestore_dev_secret_cambia_esto_1234567890
