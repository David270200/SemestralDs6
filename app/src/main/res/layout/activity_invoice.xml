<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".InvoiceActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_invoice"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/invoice_title"
        app:titleTextColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_invoice"
        app:layout_constraintBottom_toTopOf="@id/btn_print_invoice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_invoice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="StyleStore"
                        android:textColor="@color/navy_dark"
                        android:fontFamily="sans-serif-black"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Factura de compra"
                        android:textColor="@color/gray"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/divider_color" />

                    <!-- Datos generales -->
                    <TextView android:id="@+id/tv_invoice_order_number" style="@style/InvoiceLabelValue" android:layout_marginTop="16dp" tools:text="Número de orden: ORD-2024-001" />
                    <TextView android:id="@+id/tv_invoice_date" style="@style/InvoiceLabelValue" tools:text="Fecha: 28 de jun., 2024" />
                    <TextView android:id="@+id/tv_invoice_customer" style="@style/InvoiceLabelValue" tools:text="Cliente: Sarah Chen" />
                    <TextView android:id="@+id/tv_invoice_delivery_method" style="@style/InvoiceLabelValue" tools:text="Método de entrega: Retiro en tienda" />
                    <TextView android:id="@+id/tv_invoice_status" style="@style/InvoiceLabelValue" tools:text="Estado del pedido: Entregado" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/divider_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Productos"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/ll_invoice_products"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="@color/divider_color" />

                    <!-- Totales -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/subtotal_label" android:textColor="@color/gray" android:textSize="13sp" />
                        <TextView android:id="@+id/tv_invoice_subtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/black" android:textSize="13sp" tools:text="$89.99" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/delivery_fee_label" android:textColor="@color/gray" android:textSize="13sp" />
                        <TextView android:id="@+id/tv_invoice_delivery_fee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/black" android:textSize="13sp" tools:text="$0.00" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/total_label" android:textColor="@color/black" android:textStyle="bold" android:textSize="16sp" />
                        <TextView android:id="@+id/tv_invoice_total" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/navy_dark" android:textStyle="bold" android:textSize="18sp" tools:text="$89.99" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_print_invoice"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:text="@string/print_invoice"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:icon="@drawable/ic_orders"
        app:iconTint="@color/white"
        app:backgroundTint="@color/navy_dark"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
