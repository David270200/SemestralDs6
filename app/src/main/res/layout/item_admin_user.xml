<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_admin_user_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="S" />

        <TextView
            android:id="@+id/tv_admin_user_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="@id/tv_admin_user_avatar"
            app:layout_constraintStart_toEndOf="@id/tv_admin_user_avatar"
            app:layout_constraintEnd_toStartOf="@id/chip_admin_user_status"
            tools:text="Sarah Chen" />

        <TextView
            android:id="@+id/tv_admin_user_email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/gray"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_admin_user_name"
            app:layout_constraintStart_toEndOf="@id/tv_admin_user_avatar"
            app:layout_constraintEnd_toStartOf="@id/chip_admin_user_status"
            tools:text="sarah.chen@email.com" />

        <TextView
            android:id="@+id/tv_admin_user_orders"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/navy_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_admin_user_email"
            app:layout_constraintStart_toEndOf="@id/tv_admin_user_avatar"
            app:layout_constraintEnd_toStartOf="@id/chip_admin_user_status"
            tools:text="2 pedidos" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_admin_user_status"
            style="@style/Widget.Material3.Chip.Assist.Elevated"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:clickable="false"
            android:focusable="false"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            app:chipCornerRadius="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Activo" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
