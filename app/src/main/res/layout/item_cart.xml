<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iv_cart_item_image"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_product_placeholder"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/iv_cart_remove"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:padding="2dp"
            android:src="@drawable/ic_delete_trash"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tv_cart_item_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/iv_cart_item_image"
            app:layout_constraintStart_toEndOf="@id/iv_cart_item_image"
            app:layout_constraintEnd_toStartOf="@id/iv_cart_remove"
            tools:text="Oversized Linen Blazer - Cream" />

        <TextView
            android:id="@+id/tv_cart_item_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:textColor="@color/navy_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_cart_item_name"
            app:layout_constraintStart_toEndOf="@id/iv_cart_item_image"
            tools:text="$89.99" />

        <!-- Stepper de cantidad -->
        <LinearLayout
            android:id="@+id/ll_qty_stepper"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_qty_stepper"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_cart_item_price"
            app:layout_constraintStart_toEndOf="@id/iv_cart_item_image">

            <ImageView
                android:id="@+id/btn_decrease_qty"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:padding="10dp"
                android:src="@drawable/ic_minus"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tv_qty"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp"
                tools:text="1" />

            <ImageView
                android:id="@+id/btn_increase_qty"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:padding="10dp"
                android:src="@drawable/ic_add_plus"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
